{
  "ts-node": {
    "transpileOnly": true,
  },
  "include": ["src"],
  "compilerOptions": {
    "target": "esnext",
    "strict": false,
    "types": ["jest"],
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["esnext"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "paths": {
      "config": ["./src/config/config.ts"],
      "@frontend/types/*": ["../../client/src/types/*"],
      "*": ["./src/*"],
    },
  },
}
